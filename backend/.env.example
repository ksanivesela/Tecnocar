# Base de datos (Postgres)
# Nota: en desarrollo local con Docker se usa el puerto 5433 en el host para no
# chocar con una instalación nativa de Postgres en el puerto 5432 por defecto.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/tecnocar"

# JWT
JWT_SECRET="cambia-este-valor-por-uno-largo-y-aleatorio"
JWT_EXPIRES_IN="7d"

# Servidor
PORT=3000
NODE_ENV=development

# CORS: orígenes permitidos, separados por coma
CORS_ORIGINS="http://localhost:5173,https://tecnocar.byronrm.com"

# Carpeta local donde se guardan las imágenes subidas de productos
UPLOADS_DIR="uploads"
