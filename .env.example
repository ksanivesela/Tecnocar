# --- Base de datos ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_DB=tecnocar

# --- Backend ---
JWT_SECRET=cambia-este-valor-por-uno-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# --- Dominios (producción) ---
# Nota: mientras Traefik no tenga HTTPS configurado, usa http:// (no https://)
# URL pública del frontend (usada por el backend para CORS)
FRONTEND_URL=http://tecnocar.byronrm.com
# URL pública del backend (usada por el frontend para llamar a la API en build time)
BACKEND_URL=http://backtec.byronrm.com

# Para desarrollo local, usa en su lugar:
# FRONTEND_URL=http://localhost:5173
# BACKEND_URL=http://localhost:3000

# --- Dominios para las etiquetas de Traefik (solo el host, sin https://) ---
FRONTEND_DOMAIN=tecnocar.byronrm.com
BACKEND_DOMAIN=backtec.byronrm.com
ADMINER_DOMAIN=pgtec.byronrm.com
